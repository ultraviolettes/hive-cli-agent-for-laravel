{
    "name": "ultraviolettes/hive-cli-agent-for-laravel",
    "description": "Laravel agent orchestration CLI — turns GitHub backlogs and Nightwatch exceptions into parallel Claude Code agents.",
    "keywords": ["laravel", "cli", "ai", "agents", "claude", "worktree", "nightwatch"],
    "homepage": "https://github.com/ultraviolettes/hive-cli-agent-for-laravel",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/ultraviolettes/hive-cli-agent-for-laravel/issues",
        "source": "https://github.com/ultraviolettes/hive-cli-agent-for-laravel"
    },
    "authors": [
        {
            "name": "croustibat"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel-zero/framework": "^12.0.2",
        "laravel/ai": "^0.3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["hive"]
}
